# GitHub Actions secrets — used by the verify:offices CI batch job ONLY.
# These values never reach the client bundle (GitHub Pages is static).
# Set OPENROUTER_API_KEY as a repository secret in:
#   GitHub → Settings → Secrets and variables → Actions → Repository secrets
OPENROUTER_API_KEY=

# Model used for office verification in the CI batch job. Swap freely.
OPENROUTER_MODEL=anthropic/claude-3.5-sonnet
