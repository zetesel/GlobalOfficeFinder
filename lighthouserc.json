{
  "ci": {
    "collect": {
      "numberOfRuns": 1,
      "startServerCommand": "npm run preview",
      "startServerReadyPattern": "Local:",
      "url": [
        "http://localhost:4173/",
        "http://localhost:4173/company/google",
        "http://localhost:4173/country/US"
      ]
    },
    "upload": {
      "target": "temporary-public-storage"
    },
    "assert": {
      "preset": null,
      "assertions": {
        "cumulativeLayoutShift": "off",
        "categories:performance": ["error", { "minScore": 0.50 }],
        "categories:accessibility": ["error", { "minScore": 0.80 }],
        "categories:best-practices": ["error", { "minScore": 0.80 }],
        "categories:seo": ["error", { "minScore": 0.80 }],
        "csp-xss": "off",
        "errors-in-console": "off",
        "unused-javascript": "off",
        "color-contrast": "off",
        "installable-manifest": "off",
        "service-worker": "off",
        "maskable-icon": "off",
        "splash-screen": "off",
        "themed-omnibox": "off",
        "render-blocking-resources": "off",
        "uses-responsive-images": "off",
        "uses-rel-preconnect": "off"
      }
    }
  }
}
